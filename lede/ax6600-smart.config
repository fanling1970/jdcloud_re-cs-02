cat > lede/ax6600-smart.config << 'EOF'
# ====================================================================
# LEDE Configuration for JDCloud RE-CS-02 (IPQ60xx)
# Smart config - compatible with latest LEDE master
# Generated: 2026-05-31 19:31:18
# ====================================================================

# ====================================================================
# 目标架构选择（关键部分）
# ====================================================================
# 禁用所有非目标架构（防止自动配置启用错误架构）
# CONFIG_TARGET_x86 is not set
# CONFIG_TARGET_x86_64 is not set
# CONFIG_TARGET_ramips is not set
# CONFIG_TARGET_ath79 is not set
# CONFIG_TARGET_bcm27xx is not set
# CONFIG_TARGET_bcm53xx is not set
# CONFIG_TARGET_mvebu is not set

# 启用目标架构
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y

# ====================================================================
# 核心系统配置
# ====================================================================
CONFIG_TARGET_BOARD="qualcommax"
CONFIG_TARGET_SUBTARGET="ipq60xx"
CONFIG_TARGET_PROFILE="DEVICE_jdcloud_re-cs-02"
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"

# ====================================================================
# 内核版本 - 不指定，让LEDE自动选择最新
# ====================================================================
# 注释掉所有具体内核版本，让构建系统决定
# CONFIG_LINUX_6_1 is not set
# CONFIG_LINUX_5_15 is not set

# ====================================================================
# 基础软件包（最小集，确保编译成功）
# ====================================================================
CONFIG_DEFAULT_base-files=y
CONFIG_DEFAULT_busybox=y
CONFIG_DEFAULT_dropbear=y
CONFIG_DEFAULT_firewall=y
CONFIG_DEFAULT_fstools=y
CONFIG_DEFAULT_luci=y
CONFIG_DEFAULT_netifd=y
CONFIG_DEFAULT_opkg=y
CONFIG_DEFAULT_uci=y

# ====================================================================
# 必要的内核模块
# ====================================================================
CONFIG_DEFAULT_kmod-ath11k-ahb=y
CONFIG_DEFAULT_kmod-ath11k-pci=y
CONFIG_DEFAULT_kmod-gpio-button-hotplug=y
CONFIG_DEFAULT_kmod-leds-gpio=y
CONFIG_DEFAULT_kmod-usb3=y

# ====================================================================
# 文件系统
# ====================================================================
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_INITRAMFS_COMPRESSION_ZSTD=y

# ====================================================================
# 网络基础
# ====================================================================
CONFIG_DEFAULT_dnsmasq-full=y
CONFIG_DEFAULT_ip-full=y
CONFIG_DEFAULT_iptables=y
CONFIG_DEFAULT_iwinfo=y
CONFIG_DEFAULT_wpad-openssl=y
EOF
