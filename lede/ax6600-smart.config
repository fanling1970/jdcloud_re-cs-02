# ====================================================================
# LEDE精简但完整配置 - JDCloud RE-CS-02 (IPQ60xx)
# 保持精简但包含必要依赖
# ====================================================================

# =====================================================
# 内核编译修复
# =====================================================
CONFIG_WERROR=n

# =====================================================
# 核心系统配置
# =====================================================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y

# =====================================================
# 基础包（必须的）
# =====================================================
# Luci 核心
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y  # 必须添加
CONFIG_PACKAGE_luci-app-firewall=y

# 网络基础
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_ip-full=y

# 系统基础
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_default-settings=y  # 必须添加
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_urandom-seed=y

# 工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_wget-ssl=y  # 为 ddns 准备

# =====================================================
# 无线驱动（必须的）
# =====================================================
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_ath11k-firmware-ipq6018=y
CONFIG_PACKAGE_ipq-wifi-jdcloud_re-cs-02=y
CONFIG_PACKAGE_nss-firmware-ipq6018=y

# =====================================================
# 只保留 Dockerman（必须的功能）
# =====================================================
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_docker-ce=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_containerd=y

# Docker 基础内核模块
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-dax=y
CONFIG_PACKAGE_kmod-dm=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_kmod-ikconfig=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-veth=y

# =====================================================
# 临时禁用所有非必要模块
# =====================================================
# 禁用 VXLAN（导致编译错误）
# CONFIG_PACKAGE_kmod-vxlan=y

# 禁用 SSR-plus
# CONFIG_PACKAGE_luci-app-ssr-plus=y
# CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y
# CONFIG_PACKAGE_shadowsocksr-libev-alt=y

# 禁用 mosdns
# CONFIG_PACKAGE_mosdns=y
# CONFIG_PACKAGE_luci-app-mosdns=y

# 禁用 argon 主题
# CONFIG_PACKAGE_luci-theme-argon=y
# CONFIG_PACKAGE_luci-app-argon-config=y

# 禁用 DDNS 脚本（导致依赖问题）
# CONFIG_PACKAGE_ddns-scripts=y
# CONFIG_PACKAGE_ddns-scripts_aliyun=y
# CONFIG_PACKAGE_ddns-scripts_dnspod=y

# 禁用其他非必要工具
# CONFIG_PACKAGE_htop=y
# CONFIG_PACKAGE_vim-full=y
# CONFIG_PACKAGE_samba4-server=y
# CONFIG_PACKAGE_minidlna=y
